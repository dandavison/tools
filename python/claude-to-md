#!/usr/bin/env -S uv run --script
#
# /// script
# requires-python = ">=3.12"
# dependencies = []
# ///
#
# Reflow a Claude Code transcript copied from the terminal into markdown.
#
# Input lines starting with вқҜ (user) or вҸә (assistant) open a turn; subsequent
# indented lines are hard-wrapped continuations and blank lines separate
# paragraphs. Output joins each paragraph onto one line, rendering user turns
# as blockquotes and assistant turns as plain paragraphs. Box-drawing tables
# are kept verbatim inside a fenced code block so their alignment survives.
#
# By default reads from and writes to the system clipboard; a piped stdin or
# stdout overrides the respective side.

import subprocess
import sys

USER, ASSISTANT = "вқҜ", "вҸә"
BOX = set("в”Җв”Ӯв”Ңв”җв””в”ҳв”ңв”Өв”¬в”ҙв”јв”Ғв”ғв”Ҹв”“в”—в”ӣв”Јв”«в”ів”»в•Ӣв•җв•‘в•”в•—в•ҡв•қв• в•Јв•Ұв•©в•¬в•ӯв•®в•°в•Ҝ")


def main() -> None:
    text = sys.stdin.read() if not sys.stdin.isatty() else pbpaste()
    output = render(parse_turns(text))
    if sys.stdout.isatty():
        pbcopy(output)
    else:
        print(output, end="")


def parse_turns(text: str) -> list[tuple[str, list[tuple[str, str]]]]:
    turns: list[tuple[str, list[tuple[str, str]]]] = []
    role, blocks, words, rows = ASSISTANT, [], [], []

    def end_paragraph():
        if words:
            blocks.append(("p", " ".join(words)))
            words.clear()

    def end_table():
        if rows:
            blocks.append(("table", "\n".join(rows)))
            rows.clear()

    def end_turn():
        nonlocal blocks
        end_paragraph()
        end_table()
        if blocks:
            turns.append((role, blocks))
            blocks = []

    for line in text.splitlines():
        line = line.strip()
        if line[:1] in (USER, ASSISTANT):
            end_turn()
            role = line[0]
            line = line[1:].strip()
        if is_table_line(line):
            end_paragraph()
            rows.append(line)
        elif line:
            end_table()
            words.extend(line.split())
        else:
            end_paragraph()
            end_table()
    end_turn()
    return turns


def is_table_line(line: str) -> bool:
    return bool(line) and line[0] in BOX


def render(turns: list[tuple[str, list[tuple[str, str]]]]) -> str:
    out = []
    for role, blocks in turns:
        pieces = []
        for kind, content in blocks:
            if kind == "table":
                pieces.append(("table", f"```\n{content}\n```"))
            elif role == USER:
                pieces.append(("quote", f"> {content}"))
            else:
                pieces.append(("text", content))
        rendered = ""
        for i, (kind, text) in enumerate(pieces):
            if i == 0:
                rendered = text
                continue
            both_quotes = kind == "quote" and pieces[i - 1][0] == "quote"
            rendered += ("\n>\n" if both_quotes else "\n\n") + text
        out.append(rendered)
    return "\n\n".join(out) + "\n" if out else ""


def pbpaste() -> str:
    return subprocess.run(
        ["pbpaste"], capture_output=True, text=True, check=True
    ).stdout


def pbcopy(text: str) -> None:
    subprocess.run(["pbcopy"], input=text, text=True, check=True)


if __name__ == "__main__":
    main()
