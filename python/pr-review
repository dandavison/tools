#!/usr/bin/env -S uv run --script
#
# /// script
# requires-python = ">=3.12"
# dependencies = []
# ///
#
# Review a GitHub PR by driving `claude` as a subprocess.
#
# The PR metadata and full diff are fetched deterministically with `gh` and
# inlined into the prompt, so claude always sees the whole diff. claude is run
# with --safe-mode (no CLAUDE.md/AGENTS.md, skills, MCP, hooks, or plugins) and
# a read-only toolset (Read/Grep/Glob, so no skills and no mutation), letting it
# explore the local checkout for context while staying reproducible across team
# members regardless of their local config. The review streams to stdout;
# claude's thoughts and tool activity stream to stderr.
#
# Usage:
#     pr-review <github-url | pr-number>   # review the PR
#     pr-review --show-prompt [<pr>]       # print the prompt
#     pr-review --model <model> <pr>       # override the model

import argparse
import json
import re
import subprocess
import sys

DEFAULT_MODEL = "opus"

INSTRUCTIONS = """
Output a review of this PR as described below.
Where you are instructed to output text, output a small number of bulletpoints, each comprising one sentence.
When you exit due to a problem, explain the problem.

- Ensure that you are in a directory containing a clone of the PR's repo, with the commit corresponding to the PR checked out. Exit if not.

- Run the tests relevant to this PR. If they do not pass, exit.

- Describe what the author is trying to achieve. If you are not confident about this, exit.

- If their intention is not appropriate, exit.

- If there is a major flaw in their implementation that is preventing them from achieving their intention, exit.

- Study the test coverage added.
  Describe any important aspects of the PR's intention that are not tested.
  Describe any test that is not achieving what it intends to.
  Describe any test that is a false negative in the sense that, were the corresponding part of the implementation to be reverted, the test would nevertheless continue to pass.

- Describe all correctness bugs.

- Describe any other major flaws you perceive in the PR.
"""


def main() -> int:
    parser = argparse.ArgumentParser(
        prog="pr-review", description="Review a GitHub PR using claude."
    )
    parser.add_argument("pr", nargs="?", help="GitHub PR URL or number")
    parser.add_argument(
        "--show-prompt", action="store_true", help="print the prompt and exit"
    )
    parser.add_argument("--model", default=DEFAULT_MODEL, help="Anthropic model to use")
    args = parser.parse_args()

    if args.show_prompt:
        print(build_prompt(args.pr) if args.pr else INSTRUCTIONS)
        return 0

    if not args.pr:
        parser.error("a GitHub PR URL or number is required")

    validate(args.pr)
    return review(build_prompt(args.pr), args.model)


def validate(pr: str) -> None:
    require_clean_repo()
    repo = pr_url_repo(pr)
    if repo:
        require_local_clone(repo)


def require_clean_repo() -> None:
    inside = subprocess.run(
        ["git", "rev-parse", "--is-inside-work-tree"], capture_output=True, text=True
    )
    if inside.returncode != 0 or inside.stdout.strip() != "true":
        sys.exit("error: not inside a git repository")
    if subprocess.run(
        ["git", "status", "--porcelain", "--untracked-files=no"],
        capture_output=True,
        text=True,
    ).stdout.strip():
        sys.exit("error: working tree has uncommitted changes")


def require_local_clone(repo: str) -> None:
    current = gh(
        "repo", "view", "--json", "nameWithOwner", "-q", ".nameWithOwner"
    ).strip()
    if current.lower() != repo.lower():
        sys.exit(f"error: current repo is {current}, not the PR's repo {repo}")


def pr_url_repo(pr: str) -> str | None:
    m = re.match(r"https?://github\.com/([^/]+)/([^/]+)/pull/\d+", pr)
    return f"{m.group(1)}/{m.group(2)}" if m else None


def build_prompt(pr: str) -> str:
    meta = pr_metadata(pr)
    header = "\n".join(
        [
            f"Title: {meta['title']}",
            f"URL: {meta['url']}",
            f"Author: {meta['author'].get('login', '')}",
        ]
    )
    return "\n".join(
        [
            INSTRUCTIONS,
            "",
            header,
            "",
            "Description:",
            meta["body"] or "(none)",
            "",
            "Diff:",
            "```diff",
            pr_diff(pr),
            "```",
        ]
    )


def pr_metadata(pr: str) -> dict:
    out = gh("pr", "view", pr, "--json", "title,url,author,body")
    return json.loads(out)


def pr_diff(pr: str) -> str:
    return gh("pr", "diff", pr)


def gh(*args: str) -> str:
    result = subprocess.run(["gh", *args], capture_output=True, text=True)
    if result.returncode != 0:
        sys.exit(f"gh {' '.join(args)} failed: {result.stderr.strip()}")
    return result.stdout


def review(prompt: str, model: str) -> int:
    proc = subprocess.Popen(
        [
            "claude",
            "--model",
            model,
            "--safe-mode",
            "--tools",
            "Read,Grep,Glob",
            "--print",
            "--output-format",
            "stream-json",
            "--include-partial-messages",
            "--verbose",
            prompt,
        ],
        stdout=subprocess.PIPE,
        text=True,
    )
    assert proc.stdout is not None
    seen: set[str] = set()
    for line in proc.stdout:
        emit(line, seen)
    return proc.wait()


# The review text goes to stdout; claude's thoughts and tool activity go to
# stderr, so redirecting stdout captures a clean review.
def emit(line: str, seen: set[str]) -> None:
    try:
        event = json.loads(line)
    except json.JSONDecodeError:
        return
    kind = event.get("type")
    if kind == "stream_event":
        delta = event.get("event", {}).get("delta", {})
        if delta.get("type") == "text_delta":
            print(delta.get("text", ""), end="", flush=True)
        elif delta.get("type") == "thinking_delta":
            print(delta.get("thinking", ""), end="", file=sys.stderr, flush=True)
    elif kind == "assistant":
        for block in event["message"].get("content", []):
            if block.get("type") == "tool_use" and block["id"] not in seen:
                seen.add(block["id"])
                log_tool(block)
    elif kind == "user":
        for block in event["message"].get("content", []):
            if block.get("type") == "tool_result":
                log_result(block)


def log_tool(block: dict) -> None:
    args = block.get("input", {})
    detail = args.get("file_path") or args.get("path") or args.get("pattern") or ""
    print(f"\n→ {block['name']} {detail}".rstrip(), file=sys.stderr, flush=True)


def log_result(block: dict) -> None:
    content = block.get("content", "")
    if isinstance(content, list):
        content = "".join(c.get("text", "") for c in content if isinstance(c, dict))
    preview = " ".join(content.split())[:200]
    if preview:
        print(f"  {preview}", file=sys.stderr, flush=True)


if __name__ == "__main__":
    sys.exit(main())
