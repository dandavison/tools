#!/usr/bin/env -S uv run --script
#
# /// script
# requires-python = ">=3.12"
# dependencies = []
# ///
#
# Search synced AI-agent conversations, newest activity first, one hit per file.
#
# Conversations are materialized by `wormhole conversations sync` as markdown
# under ~/.wormhole/conversations/<project>/<date>-<session>.md, stamped with the
# source transcript's mtime — so `rg --sortr modified` yields true last-activity order.
#
# Usage:
#   rg-ai-conversations [DIR] PATTERN [extra rg args...]
#   rg-ai-conversations -i 'conflict polic'
#   rg-ai-conversations -A2 ReusePolicy        # add context lines
#   rg-ai-conversations . ReusePolicy          # only this project's sessions
#
# A leading DIR (an existing directory, most commonly `.`) limits the search to
# that project's sessions. Any other arguments are passed through to rg.
import os
import shlex
import subprocess
import sys
from pathlib import Path

CONVERSATIONS_DIR = Path(
    os.environ.get(
        "WORMHOLE_CONVERSATIONS_DIR", Path.home() / ".wormhole/conversations"
    )
)

DEFAULTS = ["--sortr", "modified", "-m1", "-n", "--no-heading", "-g", "*.md"]

USAGE = (
    """\
rg-ai-conversations [DIR] PATTERN [extra rg args...]

Search synced AI-agent conversations, newest activity first, one hit per file.
A leading DIR (an existing directory, most commonly `.`) limits the search to
that project's sessions. Other arguments pass through to rg.

  rg-ai-conversations -i 'conflict polic'
  rg-ai-conversations -A2 ReusePolicy        # add context lines
  rg-ai-conversations . ReusePolicy          # only this project's sessions

Searches: %s (override with WORMHOLE_CONVERSATIONS_DIR)"""
    % CONVERSATIONS_DIR
)


def main(argv: list[str]) -> int:
    if argv and argv[0] in ("-h", "--help"):
        print(USAGE, file=sys.stderr)
        return 0
    search_dir = CONVERSATIONS_DIR
    if argv and Path(argv[0]).is_dir():
        search_dir = project_conversations_dir(argv[0])
        argv = argv[1:]
    cmd = ["rg", *DEFAULTS, *argv, str(search_dir)]
    if not any(not a.startswith("-") for a in argv):
        cmd.append("-e")  # empty pattern slot at line end: cursor lands here to type
    os.environ["RGI_PREVIEW_RAW"] = (
        "1"  # bat (highlight + scroll-to-match), not mdcat rendering
    )
    os.execvp("rgi", [shlex.quote(s) for s in cmd])


def project_conversations_dir(path: str) -> Path:
    """The synced-conversations subdir for the project owning `path`.

    Conversations live under CONVERSATIONS_DIR/<project>, where <project> is the
    wormhole project name — for an ordinary checkout, the git repo's basename.
    """
    name = git_toplevel(path).name
    directory = CONVERSATIONS_DIR / name
    if not directory.is_dir():
        sys.exit(f"no synced conversations for project {name!r} ({directory})")
    return directory


def git_toplevel(path: str) -> Path:
    result = subprocess.run(
        ["git", "-C", path, "rev-parse", "--show-toplevel"],
        capture_output=True,
        text=True,
    )
    return (
        Path(result.stdout.strip()) if result.returncode == 0 else Path(path).resolve()
    )


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
