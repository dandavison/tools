#!/usr/bin/env -S uv run --script
#
# /// script
# requires-python = ">=3.12"
# dependencies = ["httpx"]
# ///
"""Query Temporal Cloud logs from Loki (LogQL) via the query-frontend HTTP API.

Logs from everything running on our EKS clusters are shipped to a central Loki
per environment. This CLI reaches that Loki through a kubectl port-forward to the
`loki-query-frontend` service (which bypasses the mTLS termination at the ALB, so
no extra auth is needed), then issues LogQL queries against the HTTP API.

Run `temporal-logs query --help` / `labels --help` for LogQL guidance and examples.
"""

from __future__ import annotations

import argparse
import json
import os
import re
import shutil
import subprocess
import sys
import time
from dataclasses import dataclass
from datetime import datetime, timedelta, timezone

import httpx

# The central Loki for each environment lives in a specific cell. We port-forward
# to its query-frontend on a per-env local port so prod and test can coexist.
ENVIRONMENTS = {
    "prod": {"cell": "o-uswe2", "port": 3100},
    "test": {"cell": "o-nj99p", "port": 3101},
}
NAMESPACE = "loki-distributed"
SERVICE = "loki-query-frontend"
REMOTE_PORT = 3100

# Loki indexes only these labels; they are the selectors inside `{...}`. Everything
# else must be extracted at query time with `| json` / `| logfmt` before filtering.
INDEXED_LABELS = [
    "cluster",
    "env",
    "k8s_app",
    "k8s_container",
    "k8s_namespace",
    "k8s_node_name",
    "k8s_pod",
]

QUERY_EPILOG = (
    """\
LogQL in 30 seconds
-------------------
A query is a stream selector `{...}` (indexed labels only) optionally followed by
filters and, for aggregations, a metric function.

Indexed labels (usable inside {}): """
    + ", ".join(INDEXED_LABELS)
    + """
  Operators inside {}: = != =~ !~   e.g. {cluster="s-cd015", k8s_pod=~"history.*"}

Line filters (like grep, applied to the raw line):
  |= "error"      contains          != "mtgox"     does not contain
  |~ "regex"      matches regex      !~ "regex"     does not match

Parse then filter non-indexed fields (most of our logs are JSON):
  {...} | json                      parse JSON, expose every field as a label
  {...} | json | level="error"      filter on a parsed field
  {...} | json | grpc_time_ms > 200 numeric comparison on a parsed field
  {...} | logfmt                    for key=value style logs
  Drop unparseable lines:  | json | __error__="" (keep parsed) or __error__!="JSONParserErr"

Metric queries (use --instant for a single value, or --step for a range):
  count_over_time({...}[5m])                          count matching lines
  sum(count_over_time({...}[5m])) by (k8s_pod)        grouped counts
  topk(10, sum(count_over_time({...}[1h])) by (error))  top-10 by a field
  When you pass --instant/--step the CLI supplies the range, so write the metric
  function WITHOUT the trailing [range]: `sum(count_over_time({...})) by (k8s_pod)`.

Examples
--------
  temporal-logs query '{cluster="s-cd015", k8s_namespace="temporal", k8s_container="history"}'
  temporal-logs query '{cluster="s-cd015", k8s_container="history"} |= `"level":"error"`' --since 30m
  temporal-logs query '{cluster="s-cd015"} | json | logging_call_at=`task_fetcher.go:434`' -o jsonl
  temporal-logs query 'topk(10, sum(count_over_time({cluster="s-cd015"} |= "error" | json | level="error")) by (error))' --instant --since 1h
  temporal-logs query '{cluster="s-cd015"} |= "shard"' --env test --from 2025-08-10T15:03:59Z --to 2025-08-10T19:04:16Z

Cost note: queries touch a lot of data. Always narrow the selector as much as you
can (cluster + namespace + container at minimum) and keep the time window tight;
`| json` adds real overhead. Log queries are truncated at --limit (default 1000).
"""
)


def main() -> int:
    parser = argparse.ArgumentParser(
        prog="temporal-logs",
        description=__doc__,
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    sub = parser.add_subparsers(dest="command", required=True)

    q = sub.add_parser(
        "query",
        help="Run a LogQL query and print matching log lines (or metric samples).",
        description="Run a LogQL query against Loki and print the results.",
        epilog=QUERY_EPILOG,
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    q.add_argument(
        "logql",
        help='LogQL query, e.g. \'{cluster="s-cd015", k8s_container="history"} |= "error"\'',
    )
    _add_common(q)
    q.add_argument(
        "--limit",
        type=int,
        default=1000,
        help="Max log lines to return (default 1000).",
    )
    q.add_argument(
        "--direction",
        choices=["forward", "backward"],
        default="backward",
        help="backward = newest first (default), forward = oldest first.",
    )
    q.add_argument(
        "--instant",
        action="store_true",
        help="Evaluate a metric query at a single instant (query end).",
    )
    q.add_argument(
        "--step",
        help="Step for a range metric query, e.g. 1m, 5m. Implies a metric (matrix) query.",
    )
    q.add_argument(
        "-o",
        "--output",
        choices=["pretty", "jsonl", "raw"],
        default="pretty",
        help="pretty: 'timestamp line' (default). jsonl: one JSON object per result. raw: log line only.",
    )
    q.set_defaults(func=cmd_query)

    lbl = sub.add_parser(
        "labels",
        help="List indexed label names, or the values of one label.",
        description="List label names, or the observed values of a single label in the time window.",
        epilog="Examples:\n  temporal-logs labels\n  temporal-logs labels cluster\n  temporal-logs labels k8s_container --env test",
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    lbl.add_argument(
        "name",
        nargs="?",
        help="Label name to list values for. Omit to list all label names.",
    )
    _add_common(lbl)
    lbl.set_defaults(func=cmd_labels)

    pf = sub.add_parser(
        "port-forward",
        help="Start (foreground) the kubectl port-forward to Loki for an environment.",
        description=(
            "Run the port-forward in the foreground. `query`/`labels` start this automatically "
            "when needed, so you rarely call this directly; use it to hold a long-lived tunnel."
        ),
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    pf.add_argument(
        "-e",
        "--env",
        choices=list(ENVIRONMENTS),
        default="prod",
        help="Environment (default prod).",
    )
    pf.set_defaults(func=cmd_port_forward)

    args = parser.parse_args()
    try:
        return args.func(args)
    except QueryError as e:
        print(f"error: {e}", file=sys.stderr)
        return 1


def _add_common(p: argparse.ArgumentParser) -> None:
    p.add_argument(
        "-e",
        "--env",
        choices=list(ENVIRONMENTS),
        default="prod",
        help="Environment (default prod).",
    )
    p.add_argument(
        "--since",
        default="1h",
        help="Look-back window ending now, e.g. 15m, 1h, 2d (default 1h). Ignored if --from is set.",
    )
    p.add_argument(
        "--from",
        dest="from_",
        help="Range start (ISO8601, e.g. 2025-08-10T15:03:59Z). Overrides --since.",
    )
    p.add_argument("--to", help="Range end (ISO8601). Defaults to now.")
    p.add_argument(
        "--addr",
        default=os.environ.get("LOKI_ADDR"),
        help="Loki base URL. Defaults to $LOKI_ADDR, else an auto port-forward on the env's local port.",
    )
    p.add_argument(
        "--no-forward",
        action="store_true",
        help="Do not auto-start a port-forward; require --addr/$LOKI_ADDR.",
    )


class QueryError(Exception):
    pass


@dataclass
class TimeRange:
    start_ns: int
    end_ns: int


def cmd_query(args: argparse.Namespace) -> int:
    tr = resolve_time_range(args)
    addr = ensure_loki(args)
    params: dict[str, str] = {"query": args.logql, "limit": str(args.limit)}

    if args.instant:
        path = "/loki/api/v1/query"
        params["time"] = str(tr.end_ns)
    else:
        path = "/loki/api/v1/query_range"
        params |= {
            "start": str(tr.start_ns),
            "end": str(tr.end_ns),
            "direction": args.direction,
        }
        if args.step:
            params["step"] = args.step

    data = loki_get(addr, path, params)
    render(data, args.output, args.direction, args.limit)
    return 0


def cmd_labels(args: argparse.Namespace) -> int:
    tr = resolve_time_range(args)
    addr = ensure_loki(args)
    params = {"start": str(tr.start_ns), "end": str(tr.end_ns)}
    path = (
        f"/loki/api/v1/label/{args.name}/values" if args.name else "/loki/api/v1/labels"
    )
    data = loki_get(addr, path, params)
    for value in data.get("data", []):
        print(value)
    return 0


def cmd_port_forward(args: argparse.Namespace) -> int:
    cell, port = ENVIRONMENTS[args.env]["cell"], ENVIRONMENTS[args.env]["port"]
    cmd = port_forward_cmd(cell, port)
    print(
        f"forwarding {args.env} ({cell}) {SERVICE} -> http://localhost:{port} (ctrl-c to stop)",
        file=sys.stderr,
    )
    require_ct()
    return subprocess.call(cmd)


def resolve_time_range(args: argparse.Namespace) -> TimeRange:
    now = datetime.now(timezone.utc)
    end = parse_time(args.to, now) if args.to else now
    if args.from_:
        start = parse_time(args.from_, now)
    else:
        start = end - parse_duration(args.since)
    if start >= end:
        raise QueryError("start time is not before end time")
    return TimeRange(to_ns(start), to_ns(end))


def parse_time(value: str, now: datetime) -> datetime:
    if value == "now":
        return now
    text = value.replace("Z", "+00:00")
    try:
        dt = datetime.fromisoformat(text)
    except ValueError as e:
        raise QueryError(
            f"cannot parse time {value!r} (use ISO8601 like 2025-08-10T15:03:59Z)"
        ) from e
    return dt if dt.tzinfo else dt.replace(tzinfo=timezone.utc)


def parse_duration(value: str) -> timedelta:
    m = re.fullmatch(r"(\d+)\s*([smhdw])", value.strip())
    if not m:
        raise QueryError(
            f"cannot parse duration {value!r} (use forms like 30m, 1h, 2d)"
        )
    n, unit = int(m.group(1)), m.group(2)
    return timedelta(
        seconds=n * {"s": 1, "m": 60, "h": 3600, "d": 86400, "w": 604800}[unit]
    )


def to_ns(dt: datetime) -> int:
    return int(dt.timestamp() * 1_000_000_000)


def loki_get(addr: str, path: str, params: dict[str, str]) -> dict:
    try:
        resp = httpx.get(f"{addr}{path}", params=params, timeout=120.0)
    except httpx.HTTPError as e:
        raise QueryError(f"request to {addr} failed: {e}") from e
    if resp.status_code != 200:
        raise QueryError(f"Loki returned {resp.status_code}: {resp.text.strip()[:500]}")
    return resp.json()


def render(payload: dict, output: str, direction: str, limit: int) -> None:
    data = payload.get("data", {})
    result_type = data.get("resultType")
    result = data.get("result", [])

    if result_type == "streams":
        render_streams(result, output, direction, limit)
    elif result_type == "matrix":
        render_matrix(result, output)
    elif result_type == "vector":
        render_vector(result, output)
    else:
        raise QueryError(f"unexpected result type {result_type!r}")


def render_streams(result: list, output: str, direction: str, limit: int) -> None:
    entries = [
        (int(ns), line, stream.get("stream", {}))
        for stream in result
        for ns, line in stream.get("values", [])
    ]
    entries.sort(key=lambda e: e[0], reverse=(direction == "backward"))
    for ns, line, labels in entries:
        if output == "raw":
            print(line)
        elif output == "jsonl":
            print(json.dumps({"ts": iso(ns), "labels": labels, "line": line}))
        else:
            print(f"{iso(ns)}  {line}")
    n = len(entries)
    note = f"{n} log lines" + (
        f" (hit --limit {limit}; results truncated)" if n >= limit else ""
    )
    print(note, file=sys.stderr)


def render_matrix(result: list, output: str) -> None:
    for series in result:
        metric = series.get("metric", {})
        if output == "jsonl":
            for ts, val in series.get("values", []):
                print(
                    json.dumps(
                        {
                            "metric": metric,
                            "ts": iso(int(float(ts) * 1e9)),
                            "value": val,
                        }
                    )
                )
        else:
            print(fmt_labels(metric))
            for ts, val in series.get("values", []):
                print(f"  {iso(int(float(ts) * 1e9))}  {val}")
    print(f"{len(result)} series", file=sys.stderr)


def render_vector(result: list, output: str) -> None:
    rows = [(s.get("metric", {}), s.get("value", [None, ""])[1]) for s in result]
    for metric, value in rows:
        if output == "jsonl":
            print(json.dumps({"metric": metric, "value": value}))
        else:
            print(f"{value}\t{fmt_labels(metric)}")
    print(f"{len(rows)} results", file=sys.stderr)


def iso(ns: int) -> str:
    return (
        datetime.fromtimestamp(ns / 1e9, tz=timezone.utc)
        .isoformat()
        .replace("+00:00", "Z")
    )


def fmt_labels(labels: dict) -> str:
    return "{" + ", ".join(f'{k}="{v}"' for k, v in sorted(labels.items())) + "}"


def ensure_loki(args: argparse.Namespace) -> str:
    if args.addr:
        return args.addr.rstrip("/")
    port = ENVIRONMENTS[args.env]["port"]
    addr = f"http://localhost:{port}"
    if loki_ready(addr):
        return addr
    if args.no_forward:
        raise QueryError(
            f"no Loki at {addr}; start a port-forward or pass --addr (--no-forward is set)"
        )
    start_port_forward(args.env, port)
    if not wait_ready(addr, timeout=25.0):
        raise QueryError(
            f"port-forward to {args.env} Loki did not become ready at {addr}"
        )
    return addr


def loki_ready(addr: str) -> bool:
    try:
        return httpx.get(f"{addr}/ready", timeout=2.0).status_code == 200
    except httpx.HTTPError:
        return False


def wait_ready(addr: str, timeout: float) -> bool:
    deadline = time.monotonic() + timeout
    while time.monotonic() < deadline:
        if loki_ready(addr):
            return True
        time.sleep(0.5)
    return False


def start_port_forward(env: str, port: int) -> None:
    cell = ENVIRONMENTS[env]["cell"]
    require_ct()
    print(
        f"starting port-forward to {env} Loki ({cell}) on :{port} ...", file=sys.stderr
    )
    subprocess.Popen(
        port_forward_cmd(cell, port),
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
        start_new_session=True,
    )


def port_forward_cmd(cell: str, port: int) -> list[str]:
    return [
        "ct",
        "kubectl",
        "--context",
        cell,
        "-n",
        NAMESPACE,
        "port-forward",
        f"service/{SERVICE}",
        f"{port}:{REMOTE_PORT}",
    ]


def require_ct() -> None:
    if shutil.which("ct") is None:
        raise QueryError(
            "ct not found on PATH; cannot establish the Loki port-forward.\n"
            "  Start one manually in another terminal (prefix with `!` in a Claude session):\n"
            f"    {' '.join(port_forward_cmd('o-uswe2', 3100))}\n"
            "  then re-run with --addr http://localhost:3100 (or set LOKI_ADDR)."
        )


if __name__ == "__main__":
    sys.exit(main())
