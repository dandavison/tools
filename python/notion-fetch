#!/usr/bin/env -S uv run --script
#
# /// script
# requires-python = ">=3.12"
# dependencies = ["pycookiecheat>=0.8"]
# ///
"""Export a Notion page to Markdown on stdout, with no LLM in the loop.

Reads your Chrome `token_v2` session cookie (via pycookiecheat), drives Notion's
private export API (enqueueTask/getTasks), downloads the resulting zip, and
prints its Markdown. This is Notion's own high-fidelity export, identical to the
"Export" menu item.

Usage:
  notion-export <notion-url> [--recursive] [--profile "Profile 1"]

Requires being logged into Notion in Chrome. The first run triggers a one-time
macOS Keychain prompt for "Chrome Safe Storage"; click "Always Allow".
"""

import argparse
import io
import json
import os
import re
import sys
import time
import urllib.error
import urllib.request
import zipfile
from pathlib import Path
from typing import Any, NoReturn

from pycookiecheat import chrome_cookies

API = "https://www.notion.so/api/v3"
UUID_RE = re.compile(
    r"[0-9a-f]{8}-?[0-9a-f]{4}-?[0-9a-f]{4}-?[0-9a-f]{4}-?[0-9a-f]{12}", re.I
)


def main() -> int:
    ap = argparse.ArgumentParser(
        description="Export a Notion page to Markdown on stdout."
    )
    ap.add_argument("url", help="Notion page URL")
    ap.add_argument("--recursive", action="store_true", help="include subpages")
    ap.add_argument(
        "--profile", help='Chrome profile, e.g. "Profile 1" (default: Default)'
    )
    ap.add_argument("--timeout", type=int, default=180, help="export wait, seconds")
    args = ap.parse_args()

    block_id = extract_block_id(args.url)
    cookies = notion_cookies(args.profile)
    token = cookies["token_v2"]

    task_id = enqueue_export(block_id, token, args.recursive)
    log(f"export task {task_id} enqueued for block {block_id}")
    export_url = poll_export(task_id, token, args.timeout)
    log(f"downloading {export_url}")
    sys.stdout.write(markdown_from_zip(download(export_url, cookies)))
    return 0


def extract_block_id(url: str) -> str:
    ids = UUID_RE.findall(url)
    if not ids:
        die(f"no page id found in URL: {url}")
    raw = ids[-1].replace("-", "").lower()
    return f"{raw[0:8]}-{raw[8:12]}-{raw[12:16]}-{raw[16:20]}-{raw[20:32]}"


def notion_cookies(profile: str | None) -> dict[str, str]:
    cookie_file = None
    if profile:
        cookie_file = (
            Path.home()
            / "Library/Application Support/Google/Chrome"
            / profile
            / "Cookies"
        )
    cookies = chrome_cookies("https://www.notion.so", cookie_file=cookie_file)
    if not cookies.get("token_v2"):
        die(
            "no token_v2 cookie for www.notion.so; log into Notion in Chrome"
            + (f" ({profile})" if profile else "")
        )
    return cookies


def enqueue_export(block_id: str, token: str, recursive: bool) -> str:
    body = {
        "task": {
            "eventName": "exportBlock",
            "request": {
                "block": {"id": block_id},
                "recursive": recursive,
                "exportOptions": {
                    "exportType": "markdown",
                    "timeZone": local_timezone(),
                    "locale": "en",
                },
            },
        }
    }
    return api_post("enqueueTask", body, token)["taskId"]


def poll_export(task_id: str, token: str, timeout_s: int) -> str:
    deadline = time.monotonic() + timeout_s
    while time.monotonic() < deadline:
        results = (
            api_post("getTasks", {"taskIds": [task_id]}, token).get("results") or []
        )
        if not results:
            die(f"task {task_id} not found")
        task = results[0]
        state = task.get("state")
        if state == "success":
            return task["status"]["exportURL"]
        if state == "failure":
            die(f"export failed: {json.dumps(task.get('error') or task.get('status'))}")
        status = task.get("status") or {}
        log(f"  state={state} pagesExported={status.get('pagesExported')}")
        time.sleep(2)
    die(f"export timed out after {timeout_s}s")


def download(url: str, cookies: dict[str, str]) -> bytes:
    header = "; ".join(f"{k}={v}" for k, v in cookies.items())
    req = urllib.request.Request(url, headers={"Cookie": header})
    with urllib.request.urlopen(req, timeout=120) as resp:
        return resp.read()


def markdown_from_zip(data: bytes) -> str:
    zf = zipfile.ZipFile(io.BytesIO(data))
    names = sorted(n for n in zf.namelist() if n.lower().endswith(".md"))
    if not names:
        die(f"no markdown in export zip (entries: {zf.namelist()[:10]})")
    if len(names) == 1:
        return zf.read(names[0]).decode("utf-8")
    return "\n\n\n".join(f"<!-- {n} -->\n\n{zf.read(n).decode('utf-8')}" for n in names)


def api_post(path: str, body: dict[str, Any], token: str) -> dict[str, Any]:
    req = urllib.request.Request(
        f"{API}/{path}",
        data=json.dumps(body).encode(),
        headers={"Content-Type": "application/json", "Cookie": f"token_v2={token}"},
        method="POST",
    )
    try:
        with urllib.request.urlopen(req, timeout=30) as resp:
            return json.loads(resp.read())
    except urllib.error.HTTPError as e:
        die(
            f"POST {path} -> {e.code} {e.reason}: {e.read().decode(errors='replace')[:500]}"
        )


def local_timezone() -> str:
    link = Path("/etc/localtime")
    if link.is_symlink():
        target = os.readlink(link)
        if "zoneinfo/" in target:
            return target.split("zoneinfo/", 1)[1]
    return "UTC"


def log(msg: str) -> None:
    print(msg, file=sys.stderr)


def die(msg: str) -> NoReturn:
    print(f"error: {msg}", file=sys.stderr)
    sys.exit(1)


if __name__ == "__main__":
    sys.exit(main())
