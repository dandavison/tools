#!/bin/bash
# Run the app picker (fd | rg | fzf) in a modal tmux popup and open the choice.

# tmux popups (and bind-key) inherit a stripped PATH, so make the picker's tools
# reachable regardless of how this is launched.
export PATH="$HOME/bin:/opt/homebrew/bin:$PATH"

pick() {
    local app
    app="$(command fd -d 1 '.+\.app' /Applications ~/Applications/Chrome\ Apps.localized/ |
        rg -r '$2$1' '^(.*/([^/]+)\.app)/?$' |
        fzf --with-nth 1 -d / |
        sed -E 's,[^/]+/,/,')"
    [ -n "$app" ] && DELTA_FEATURES="" open "$app"
}

if [ "$1" = "--pick" ]; then
    pick
    exit
fi

[ -n "$TMUX" ] || { echo "Error: f-open-app must be run inside tmux" >&2; exit 1; }

tmux display-popup -E -w 60% -h 70% -b rounded -T " open app " \
    "$(printf '%q' "$(readlink -f "$0")") --pick"
