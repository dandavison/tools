#!/usr/bin/env bash
report_only=
[[ "$1" == "-n" ]] && report_only=1
REPORT_ONLY="$report_only" python3 - <<'EOF'
import plistlib, pathlib, os
report_only = bool(os.environ["REPORT_ONLY"])
p = pathlib.Path.home() / "Library/Preferences/com.apple.LaunchServices/com.apple.launchservices.secure.plist"
island, finicky = "io.island.island", "se.johnste.finicky"
d = plistlib.loads(p.read_bytes())
if not report_only:
    for h in d["LSHandlers"]:
        if h.get("LSHandlerURLScheme") in ("http", "https"):
            h["LSHandlerRoleAll"] = finicky if h["LSHandlerRoleAll"].lower() == island else island
    p.write_bytes(plistlib.dumps(d, fmt=plistlib.FMT_BINARY))
    d = plistlib.loads(p.read_bytes())
print(next(h["LSHandlerRoleAll"] for h in d["LSHandlers"] if h.get("LSHandlerURLScheme") == "https"))
EOF
[[ -n "$report_only" ]] || killall lsd 2>/dev/null || :
