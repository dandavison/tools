#!/usr/bin/env bash
#
# claude-conversation-apply
#
# Three-level fzf picker that dispatches a Claude Code conversation to a
# single-conversation tool:
#   1. pick a project (the repo directory whose conversations you want)
#   2. pick a conversation within it
#   3. pick an action
# then exec `<action> <session-id>`.
#
# An action is any sibling script named claude-session-* in this codebase's
# bash/ or python/ dirs. The dispatch contract: a script operating on a single
# Claude conversation is named claude-session-* and takes the session id (full,
# unique prefix, or name) as its first positional argument.

set -euo pipefail
shopt -s nullglob

projects_dir="${CLAUDE_PROJECTS_DIR:-$HOME/.claude/projects}"
tools_root=$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)

[[ -d $projects_dir ]] || { echo "No projects dir: $projects_dir" >&2; exit 1; }
command -v fzf >/dev/null || { echo "fzf is required" >&2; exit 1; }
command -v jq  >/dev/null || { echo "jq is required" >&2; exit 1; }

# Level 1: pick a project. Display the real cwd (read from any record that has
# one), falling back to the de-slugified directory name.
project=$(
    for d in "$projects_dir"/*/; do
        d=${d%/}
        logs=("$d"/*.jsonl)
        (( ${#logs[@]} )) || continue
        cwd=$(jq -rc 'select(.cwd) | .cwd' "${logs[@]}" 2>/dev/null | head -1)
        [[ -z $cwd ]] && cwd=$(basename "$d" | tr '-' '/')
        printf '%s\t%s\n' "$cwd" "$d"
    done | sort -u |
    fzf --with-nth=1 --delimiter='\t' --prompt='project> ' \
        --header='Select a project (repo)' |
    cut -f2
)
[[ -n ${project:-} ]] || exit 0

# Level 2: pick a conversation. Display ai-title (or first user prompt) + date.
conversation=$(
    for f in "$project"/*.jsonl; do
        title=$(jq -rc 'select(.type=="ai-title") | .aiTitle' "$f" 2>/dev/null | tail -1)
        if [[ -z $title ]]; then
            title=$(jq -rc 'select(.type=="user" and (.message.content|type=="string") and (.isMeta != true)) | .message.content' "$f" 2>/dev/null \
                | head -1 | tr '\n' ' ' | cut -c1-70)
        fi
        date=$(jq -rc 'select(.timestamp) | .timestamp' "$f" 2>/dev/null | head -1 | cut -c1-16)
        printf '%s\t%s  %s\n' "$f" "${date:-?}" "${title:-(untitled)}"
    done |
    fzf --with-nth=2.. --delimiter='\t' --prompt='conversation> ' \
        --header='Select a conversation' |
    cut -f1
)
[[ -n ${conversation:-} ]] || exit 0

session_id=$(basename "$conversation" .jsonl)

# Level 3: pick an action (any claude-session-* tool) and dispatch.
action=$(
    for f in "$tools_root"/bash/claude-session-* "$tools_root"/python/claude-session-*; do
        [[ -x $f ]] || continue
        printf '%s\t%s\n' "$f" "$(basename "$f")"
    done |
    fzf --with-nth=2 --delimiter='\t' --prompt='action> ' \
        --header="Apply to ${session_id:0:8}" |
    cut -f1
)
[[ -n ${action:-} ]] || exit 0

exec "$action" "$session_id"
