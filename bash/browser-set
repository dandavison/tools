#!/usr/bin/env bash
# Set the default browser to chrome, finicky, or island (any unique,
# case-insensitive prefix works, e.g. "c", "F", "isl"). No arg: report current.
python3 - "$@" <<'EOF'
import plistlib, pathlib, sys

BROWSERS = {
    "chrome": "com.google.chrome",
    "finicky": "se.johnste.finicky",
    "island": "io.island.island",
}

p = pathlib.Path.home() / "Library/Preferences/com.apple.LaunchServices/com.apple.launchservices.secure.plist"

target = None
if len(sys.argv) > 1:
    prefix = sys.argv[1].lower()
    matches = [name for name in BROWSERS if name.startswith(prefix)]
    if len(matches) != 1:
        sys.exit(f"error: {sys.argv[1]!r} is not a unique prefix of: {', '.join(BROWSERS)}")

d = plistlib.loads(p.read_bytes())
if len(sys.argv) > 1:
    target = BROWSERS[matches[0]]
    for h in d["LSHandlers"]:
        if h.get("LSHandlerURLScheme") in ("http", "https"):
            h["LSHandlerRoleAll"] = target
    p.write_bytes(plistlib.dumps(d, fmt=plistlib.FMT_BINARY))
    d = plistlib.loads(p.read_bytes())
print(next(h["LSHandlerRoleAll"] for h in d["LSHandlers"] if h.get("LSHandlerURLScheme") == "https"))
EOF
status=$?
[[ $# -eq 0 || $status -ne 0 ]] || killall lsd 2>/dev/null || :
exit $status
